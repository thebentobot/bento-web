---
import { Icon } from "astro-icon/components";

export interface Feature {
    name: string;
    icon: string;
    description: string;
}

export interface FeatureImagePreviewProps {
    features: Feature[];
    right?: boolean;
    left?: boolean;
    title: string;
    subtitle?: string;
    description?: string;
    reversed?: boolean;
}

const {
    features,
    title,
    subtitle,
    description,
    reversed = false,
} = Astro.props as FeatureImagePreviewProps;
---

<div class="overflow-hidden dark:bg-black bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div
            class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2"
        >
            <div class={`lg:pt-4 ${reversed ? "lg:order-2 lg:pl-8" : "lg:pr-8"}`}>
                <div class="lg:max-w-lg feature-description">
                    {
                        subtitle && (
                            <h2 class="text-base font-semibold leading-7 text-yellow-400">
                                {subtitle}
                            </h2>
                        )
                    }
                    <h1
                        id={title}
                        class="mt-2 text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl"
                    >
                        {title}
                    </h1>
                    {
                        description && (
                            <p
                                class="mt-4 text-lg leading-7 text-zinc-600 dark:text-gray-200"
                                set:html={description}
                            />
                        )
                    }
                    <dl
                        class="mt-10 max-w-xl flex flex-col gap-y-8 text-base leading-7 text-zinc-600 dark:text-gray-300 lg:max-w-none"
                    >
                        {
                            features.map((feature) => (
                                <div class="relative pl-9">
                                    <dt class="inline font-semibold text-zinc-900 dark:text-gray-50">
                                        <Icon
                                            name={feature.icon}
                                            class="absolute left-1 top-1 h-5 w-5 text-yellow-600"
                                            aria-hidden="true"
                                        />
                                        {feature.name}
                                    </dt>{" "}
                                    <dd class="inline" set:html={feature.description} />
                                </div>
                            ))
                        }
                    </dl>
                    <slot name="cta" />
                </div>
            </div>
            <div class={`flex items-center ${reversed ? "lg:order-1 lg:pr-8" : ""}`}>
                <slot name="discord" />
            </div>
        </div>
    </div>
</div>
